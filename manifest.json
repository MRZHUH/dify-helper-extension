{
  "manifest_version": 3,
  "name": "Dify Helper",
  "version": "0.3.0",
  "description": "Floating overlay on cloud.dify.ai showing tenant, account, subscription, and current app/workflow info. Copy as Markdown.",
  "minimum_chrome_version": "102",
  "host_permissions": ["https://cloud.dify.ai/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://cloud.dify.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
